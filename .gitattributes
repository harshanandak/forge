# Enforce LF line endings on all text files
* text=auto eol=lf

# Single-binary embedded asset trees — force LF explicitly so the bytes Bun embeds
# are identical on Windows dev boxes and Linux/macOS CI (step-3 cross-compile targets
# all embed the same content). Placed BEFORE the binary rules so images still win.
skills/** text eol=lf
rules/** text eol=lf
docs/** text eol=lf
scripts/** text eol=lf
.forge/hooks/** text eol=lf
.claude/scripts/** text eol=lf
# Plugin hooks are a cross-platform POLYGLOT (superpowers pattern): run-hook.cmd
# runs under cmd.exe on Windows AND under sh on Unix (the `: << 'CMDBLOCK'`
# heredoc). It MUST be LF — CRLF makes the Unix heredoc terminator (`CMDBLOCK\r`)
# never match and breaks the hook on macOS/Linux. cmd.exe tolerates LF for this
# straight-line script (no labels/goto). Matches superpowers' own `*.cmd text eol=lf`.
plugin/hooks/run-hook.cmd text eol=lf
plugin/hooks/session-start text eol=lf
AGENTS.md text eol=lf

# Binary files — do not modify
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Use bd merge for beads JSONL files
.beads/issues.jsonl merge=beads

.github/workflows/*.lock.yml linguist-generated=true merge=ours