{
  "id": "cline",
  "name": "Cline",
  "version": "1.0.0",
  "description": "VS Code agent extension",
  "homepage": "https://github.com/cline/cline",
  "capabilities": {
    "commands": true,
    "skills": false,
    "hooks": false
  },
  "directories": {
