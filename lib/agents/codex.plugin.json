{
  "id": "codex",
  "name": "OpenAI Codex CLI",
  "version": "1.0.0",
  "description": "OpenAI's terminal coding agent",
  "homepage": "https://github.com/openai/codex",
  "capabilities": {
    "commands": true,
    "skills": true,
    "hooks": false
  },
  "directories": {
    "skills": ".codex/skills",
