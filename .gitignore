# Local environment variables (API keys, secrets)
.env.local
.env
.env.*.local

# Dependencies
node_modules/
.codex-tools/

# Build outputs
dist/
build/
graphify-out/

# Single-binary build (Step 2): generated Bun embed manifest + compiled binary.
# Regenerated by `bun run build:binary` before every `bun build --compile`.
lib/embedded-assets.generated.mjs
forge-bin
forge-bin.exe

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Test coverage
coverage/
.nyc_output/

# Mutation testing (Stryker)
.stryker-tmp/
stryker-report/

# Benchmark results
benchmark-results.json

# Test dashboard
test-dashboard.json
test-results/*
!test-results/.gitkeep

# Temporary files
*.tmp
*.temp

# Claude Code local settings
.claude/settings.json
.claude/settings.local.json

# Skills (local, populated by skills.sh or skills CLI — not committed)
.skills/
skills-lock.json

# Agent skill dirs populated at setup time as real file copies (forge setup /
# skills-sync populateAgentSkills), not symlinks. These are gitignored because
# they are regenerated locally from the canonical skills/ source. The one
# EXCEPTION is .agents/skills: it is committed (NOT ignored below) as Codex's
# repo-local discovery path — checked in so a teammate who clones WITHOUT running
# `forge setup` still gets Forge skills/stages auto-discovered. A pre-commit hook
# (scripts/sync-agent-skills.js) keeps it byte-identical to skills/, and the drift
# gate enforces parity. .codex/skills feeds nothing at runtime (Codex reads
# .agents/skills repo-locally + installs globally to $CODEX_HOME/skills), so it
# stays gitignored rather than committed.
.goose/
.augment/
.claude/skills/
.codex/skills/
.cursor/skills/
.github/skills/

# MCP local configuration (use .mcp.json.example as template)
.mcp.json

# Local planning notes
docs/planning/

# Git worktrees (created by /plan Phase 3 for isolated /dev sessions)
.worktrees/

# Eval logs (generated by command eval pipeline, session-specific)
.forge/eval-logs/

# PR monitor runtime state (per-PR events/snapshot/watch.pid, written while a
# push or shepherd pass runs). Machine- and PR-specific — never source.
.forge/pr-monitor/

# Test fixtures (generated by test-env/automation/setup-fixtures.sh)
# These are recreated before tests run in CI and locally
test-env/fixtures/*

# Cursor hooks runtime state (auto-generated, not versioned)
.cursor/hooks/state/

# Lefthook generated hook shims (auto-generated, not versioned)
.lefthook/

# Beads / Dolt files (local runtime/export state, not versioned)
.beads/
.dolt/
*.db
.beads-credential-key

# Forge freshness token (ephemeral validate/ship state)
.forge-freshness

# Forge push nonce token (ephemeral one-time lefthook skip)
.forge-push-token
.forge/*-body.md
