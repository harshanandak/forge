# Local environment variables (API keys, secrets)
.env.local
.env
.env.*.local

# Dependencies
node_modules/
.codex-tools/

# Build outputs
dist/
build/
graphify-out/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Test coverage
coverage/
.nyc_output/

# Mutation testing (Stryker)
.stryker-tmp/
stryker-report/

# Benchmark results
benchmark-results.json

# Test dashboard
test-dashboard.json
test-results/*
!test-results/.gitkeep

# Temporary files
*.tmp
*.temp

# Claude Code local settings
.claude/settings.json
.claude/settings.local.json

# Skills (local, populated by skills.sh or skills CLI — not committed)
.skills/
skills-lock.json

# Agent skill dirs populated at setup time as real file copies (forge setup /
# skills-sync populateAgentSkills), not symlinks. ALL of them are gitignored
# because they are generated locally from the canonical skills/ source — skills/
# is the ONLY committed skill source. Contributors run `forge setup` after clone
# to regenerate these mirrors (.agents/skills is Codex's repo-local discovery
# path; .codex/skills feeds nothing at runtime but is kept in drift parity).
.goose/
.augment/
.agents/skills/
.claude/skills/
.codex/skills/
.cursor/skills/
.github/skills/

# MCP local configuration (use .mcp.json.example as template)
.mcp.json

# Local planning notes
docs/planning/

# Git worktrees (created by /plan Phase 3 for isolated /dev sessions)
.worktrees/

# Eval logs (generated by command eval pipeline, session-specific)
.forge/eval-logs/

# Test fixtures (generated by test-env/automation/setup-fixtures.sh)
# These are recreated before tests run in CI and locally
test-env/fixtures/*

# Cursor hooks runtime state (auto-generated, not versioned)
.cursor/hooks/state/

# Lefthook generated hook shims (auto-generated, not versioned)
.lefthook/

# Beads / Dolt files (local runtime/export state, not versioned)
.beads/
.dolt/
*.db
.beads-credential-key

# Forge freshness token (ephemeral validate/ship state)
.forge-freshness

# Forge push nonce token (ephemeral one-time lefthook skip)
.forge-push-token
.forge/*-body.md
