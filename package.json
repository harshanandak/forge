{
  "name": "forge-workflow",
  "version": "0.1.0-beta.3",
  "description": "Local runtime control plane for AI-assisted engineering workflows, gates, evidence, and all AI agents",
  "bin": {
    "forge": "bin/forge.js",
    "forge-workflow": "bin/forge.js",
    "forge-preflight": "bin/forge-preflight.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test --timeout 15000",
    "test:setup": "bash test-env/automation/setup-fixtures.sh",
    "test:all": "bun run test:setup && bun test --timeout 15000",
    "test:coverage": "c8 --check-coverage bun test --timeout 15000",
    "test:ci:shard": "node scripts/test-ci-shard.js",
    "typecheck": "echo 'No TypeScript in project - skipping type check'",
    "gen:manifest": "node scripts/gen-command-manifest.js",
    "gen:manifest:check": "node scripts/gen-command-manifest.js --check",
    "prebuild": "node scripts/gen-command-manifest.js",
    "lint": "eslint . --max-warnings 0",
    "check": "node scripts/validate.js",
    "prepare": "lefthook install || echo 'Note: lefthook not installed. Git hooks disabled. Run: bun add -d lefthook'",
    "setup": "node ./bin/forge.js setup",
    "help": "node ./bin/forge.js --help",
    "gen:assets": "bun scripts/gen-embedded-assets.mjs",
    "build:binary": "bun scripts/gen-embedded-assets.mjs && bun build --compile --define FORGE_COMPILED=true ./bin/forge.js --outfile forge-bin",
    "parity:binary": "bun scripts/parity-check.mjs",
    "validate:yaml": "find . \\( -name '*.yml' -o -name '*.yaml' \\) | grep -v node_modules | while IFS= read -r file; do echo \"Checking $file...\" && bun x js-yaml \"$file\" > /dev/null || exit 1; done",
    "test:mutation": "npx stryker run",
    "test:benchmark": "node scripts/benchmark.js --output test-results/benchmark-results.json --profile-dir test-results/benchmark-profiles",
    "test:benchmark:full": "node scripts/benchmark.js --output test-results/benchmark-full-results.json --profile-dir test-results/benchmark-full-profiles --group full-suite --group validate",
    "test:full:parallel": "node scripts/test-full-suite.js",
    "test:dashboard": "node scripts/test-dashboard.js",
    "test:profile": "node scripts/test-profile.js --input-dir test-results --output test-results/test-profile.json --label local",
    "test:randomized": "bun test --timeout 15000 --randomize",
    "test:rerun": "bun test --timeout 15000 --rerun-each 2",
    "agentic:sync": "node scripts/sync-agentic-workflow.js"
  },
  "peerDependencies": {
    "lefthook": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "lefthook": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@stryker-mutator/core": "^9.6.0",
    "c8": "^11.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.3.0",
    "js-yaml": "^5.1.0",
    "lefthook": "^2.1.4",
    "typescript": "7.0.2"
  },
  "keywords": [
    "ai",
    "workflow",
    "tdd",
    "agents-md",
    "claude-code",
    "cursor",
    "codex",
    "development",
    "testing"
  ],
  "author": "Harsha Nandak",
  "license": "MIT",
  "engines": {
    "node": ">=22.16.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshanandak/forge.git"
  },
  "homepage": "https://github.com/harshanandak/forge#readme",
  "bugs": {
    "url": "https://github.com/harshanandak/forge/issues"
  },
  "files": [
    "bin/",
    "lib/",
    "rules/",
    "skills/",
    ".claude/rules/",
    ".claude/scripts/",
    ".claude/skills/",
    ".cursor/",
    "!.cursor/node_modules/",
    "scripts/",
    "!scripts/github-beads-sync/",
    "!scripts/github-beads-sync.config.json",
    "!scripts/**/*.test.js",
    ".github/PLUGIN_TEMPLATE.json",
    ".forge/hooks/",
    ".forge/protected-paths.yaml",
    "CHANGELOG.md",
    "QUICKSTART.md",
    "docs/*.md",
    "docs/architecture/**/*.md",
    "docs/guides/*.md",
    "docs/reference/*.md",
    "docs/forge/*.md",
    "install.sh",
    "lefthook.yml",
    "AGENTS.md",
    "CLAUDE.md",
    ".mcp.json.example"
  ],
  "dependencies": {
    "@babel/parser": "^8.0.0",
    "fastest-levenshtein": "^1.0.16",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "eslint": "^10.0.2",
    "fast-uri": "^3.1.2",
    "flatted": "3.4.2",
    "minimatch": "10.2.4",
    "brace-expansion": "5.0.6",
    "lodash": "4.18.1"
  },
  "c8": {
    "lines": 80,
    "branches": 80,
    "functions": 80,
    "statements": 80,
    "exclude": [
      "test/**",
      "test-env/**",
      "**/*.test.js",
      "**/*.spec.js",
      "coverage/**",
      ".forge/hooks/**",
      "bin/forge.js"
    ],
    "reporter": [
      "text",
      "lcov",
      "html"
    ]
  }
}
